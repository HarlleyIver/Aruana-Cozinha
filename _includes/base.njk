<!doctype html>
<html lang="pt-BR">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{{ title }} | Aruana Cozinha</title>
<meta name="description" content="{{ resumo if resumo else 'Blog da Aruana Cozinha. Eventos, encontros e receitas de hospitalidade brasileira em Sao Paulo.' }}" />
<meta name="theme-color" content="#c0431f" />

<!-- Open Graph: cada post ganha o proprio preview no WhatsApp e nas redes -->
<meta property="og:type" content="article" />
<meta property="og:title" content="{{ title }} | Aruana Cozinha" />
<meta property="og:description" content="{{ resumo if resumo else 'Comida que reune, afeta e conta historias.' }}" />
<meta property="og:locale" content="pt_BR" />
{% if imagem %}<meta property="og:image" content="{{ imagem }}" />{% endif %}

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@400;500;600;700&family=Caveat:wght@500;600;700&family=Nunito:ital,wght@0,400;0,500;0,600;0,700;0,800;1,500&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="/assets/blog.css" />
</head>
<body>
{% include "symbols.njk" %}

<header>
  <div class="wrap nav">
    <a href="/" class="brand" aria-label="Aruana Cozinha"><b>aruana</b><span>cozinha</span></a>
    <nav class="nav-links">
      <a class="link" href="/blog/">Blog</a>
      <a class="link" href="/#aruana">A Aruana</a>
      <a class="link" href="/#servicos">O que fazemos</a>
      <a class="link" href="/#encontros">Encontros</a>
      <a class="link" href="/#contato">Contato</a>
    </nav>
    <div class="nav-cta">
      <a class="btn btn-primary" href="https://wa.me/5511984497554?text=Ol%C3%A1!%20Vim%20pelo%20site%20da%20Aruana%20Cozinha%20e%20gostaria%20de%20um%20or%C3%A7amento%20para%20o%20meu%20evento." target="_blank" rel="noopener">Fale comigo</a>
    </div>
  </div>
</header>

<main class="blog-main">
{{ content | safe }}
</main>

<footer>
  <div class="wrap">
    <div class="foot-grid">
      <div>
        <div class="brand" style="margin-bottom:.6rem"><b style="font-size:1.6rem;font-family:Fredoka;font-weight:700">aruana</b><br><span style="font-family:Fredoka;letter-spacing:.42em;font-size:.7rem;text-transform:uppercase">cozinha</span></div>
        <p class="tag">Uma marca feita de sabor, afeto, cultura e encontros.</p>
      </div>
      <div>
        <h4>Navegue</h4>
        <a class="fl" href="/blog/">Blog</a>
        <a class="fl" href="/#aruana">A Aruana</a>
        <a class="fl" href="/#servicos">O que fazemos</a>
        <a class="fl" href="/#encontros">Encontros</a>
      </div>
      <div>
        <h4>Fale com a gente</h4>
        <a class="fl" href="https://wa.me/5511984497554?text=Ol%C3%A1!%20Vim%20pelo%20site%20da%20Aruana%20Cozinha." target="_blank" rel="noopener">WhatsApp: 11 98449 7554</a>
        <a class="fl" href="https://instagram.com/aruanacozinha" target="_blank" rel="noopener">Instagram: @aruanacozinha</a>
        <span class="fl" style="cursor:default">Sao Paulo, Brasil</span>
      </div>
    </div>
    <div class="foot-bottom">
      <span>Aruana Cozinha. Hospitalidade brasileira atraves da cozinha.</span>
      <span>Site desenvolvido por <a href="/">IverCode</a></span>
    </div>
  </div>
</footer>

