---
layout: base.njk
---
<article class="post">
  <a class="post-back" href="/blog/">&larr; voltar para o blog</a>
  <span class="eyebrow terra">encontro</span>
  <h1 class="post-title">{{ title }}</h1>
  <p class="post-meta">{{ date | dataBr }}{% if local %} &middot; {{ local }}{% endif %}</p>
  {% if imagem %}<img class="post-cover" src="{{ imagem }}" alt="{{ title }}" />{% endif %}
  <div class="post-body">
{{ content | safe }}
  </div>
  <div class="post-cta">
    <p>Quer um encontro assim no seu evento?</p>
    <a class="btn btn-primary" href="/#contato">Pedir um orcamento</a>
  </div>
</article>
